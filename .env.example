# Option 1: paste your Linear personal API key (from Settings → API → Personal API Keys)
LINEAR_GRAPHQL_API=your_linear_personal_api_key_here

# Option 2: path to a file containing the key (same file as in your shell, e.g. zshrc)
# LINEAR_GRAPHQL_API_FILE=/path/to/linear_graphql_api.txt

# GitHub (optional — for metrics / PR duration and backfill). Fine-grained: Pull requests + Issues read on selected repos.
# You can export SIDECAR_TOKEN from your shell (e.g. zshrc) or set it here.
# SIDECAR_TOKEN=

# Fallback if SIDECAR_TOKEN is unset (e.g. other users prefer a generic name).
# GITHUB_TOKEN=

# GitHub refresh tuning (optional). Cooldown skips full pull-list + PR metadata sync on dashboard Refresh to speed it up; Alt+click Refresh forces sync.
# SIDECAR_GITHUB_REFRESH_COOLDOWN_SEC=120
# How long cached PR rows stay “fresh” without Alt+click (seconds).
# SIDECAR_GITHUB_PR_META_FRESH_SEC=14400
# Max pages of GET /repos/.../pulls per repo per sync (100 PRs per page).
# SIDECAR_GITHUB_PULL_PAGES=8
